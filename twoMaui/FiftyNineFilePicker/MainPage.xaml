<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FiftyNineFilePicker.MainPage">

    <ScrollView>
        <VerticalStackLayout>
            <HorizontalStackLayout>
            <Button Text="Datei auswählen" Clicked="Button_Clicked"></Button>

                <Button Text="Choose multiple files" Clicked="Button_Clicked_1"></Button>
                <Button Text="Choose .cs file" Clicked="ChooseCsFileButton_Clicked"></Button>
                <Button Text="Choose Foler" Clicked="ChooseFolderButtonClicked"></Button>
         </HorizontalStackLayout>
            <Editor
            x:Name="eFileContent"
            IsReadOnly="True"
            HeightRequest="300"/>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
