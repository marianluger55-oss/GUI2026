<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FourtyOneTabNavigation.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:FourtyOneTabNavigation"
    Title="FourtyOneTabNavigation">

    <TabBar>
        <Tab Title="Seite1" Icon="applelogo.png">
            <ShellContent Title="Tab1">
                <ContentPage>
                    <Label Text="Welcome to Homepage"></Label>
                </ContentPage>
            </ShellContent>
        </Tab>
        <Tab Title="Seite2" Icon="shield.png">
            <ShellContent Title="Tab2">
                <ContentPage>
                    <Label Text="Welcome to Tab2"></Label>
                </ContentPage>
            </ShellContent>
        </Tab>
        <Tab Title="Main">
            <ShellContent ContentTemplate="{DataTemplate local:MainPage}">
                
            </ShellContent>
        </Tab>
    </TabBar>
</Shell>
