<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HerbariumLearnApp.MainPage"
             Title="Herbarium Lern App">
                
             

    <ScrollView>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="100" />
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Stroke="LightGray" StrokeThickness="3" Grid.Row="0" Grid.Column="0" 
                <HorizontalStackLayout>
                <Button
                    Text="Verzeichnis auswählen:" 
                            Clicked="Button_Clicked">
                        <Label x:Name="lFolder"></Label>
                    </Button>
                </HorizontalStackLayout>
            </Border>
            <Border Stroke="LightGray" StrokeThickness="3" Grid.Row="0" Grid.Column="1"></Border>
            <Border Stroke="LightGray" StrokeThickness="3" Grid.Row="1" Grid.Column="0"></Border>
            <Border Stroke="LightGray" StrokeThickness="3" Grid.Row="1" Grid.Column="1"></Border>
        </Grid>
    </ScrollView>

</ContentPage>
