<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="HerbariumLearnApp.MainPage"
    Title="Herbarium Lern App">

    <ScrollView>

        <Grid Padding="15"
              RowSpacing="10">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0"
                    Stroke="#D0D0D0"
                    StrokeShape="RoundRectangle 15"
                    Padding="15">

                <VerticalStackLayout Spacing="10">

                    <Grid ColumnDefinitions="*,Auto">

                        <Button Text="📁 Verzeichnis wählen"
                                Clicked="Verzeichnisauswählen"
                                BackgroundColor="#4CAF50"
                                TextColor="White"
                                CornerRadius="10"/>

                        <Label Grid.Column="1"
                               x:Name="lblProgress"
                               Text="0 / 0"
                               FontAttributes="Bold"
                               VerticalOptions="Center"/>
                    </Grid>
                    <Switch>

                    </Switch>

                    <Label x:Name="eFolderContent"
                           TextColor="Gray"
                           FontSize="12"/>

                    <ProgressBar x:Name="pbProgress"
                                 Progress="0"/>

                </VerticalStackLayout>

            </Border>

            <!-- MAIN CONTENT -->
            <Grid Grid.Row="1"
                  ColumnDefinitions="2*,1*"
                  ColumnSpacing="15">

                <!-- IMAGE AREA -->
                <Border Grid.Column="0"
                        Stroke="#D0D0D0"
                        StrokeShape="RoundRectangle 15"
                        Padding="0">

                    <Grid RowDefinitions="*,Auto">

                        <CarouselView
                            x:Name="cvPlants"
                            IndicatorView="imgIndicator"
                            HorizontalOptions="Fill"
                            VerticalOptions="Fill">

                            <CarouselView.ItemTemplate>
                                <DataTemplate>

                                    <Grid>

                                        <Image
                                            Source="{Binding .}"
                                            Aspect="AspectFit"
                                            HorizontalOptions="Fill"
                                            VerticalOptions="Fill" />

                                    </Grid>

                                </DataTemplate>
                            </CarouselView.ItemTemplate>

                        </CarouselView>

                        <IndicatorView
                            x:Name="imgIndicator"
                            Grid.Row="1"
                            HorizontalOptions="Center"
                            Margin="0,5"/>

                    </Grid>

                </Border>

                <!-- INPUT AREA -->
                <Border Grid.Column="1"
                        Stroke="#D0D0D0"
                        StrokeShape="RoundRectangle 15"
                        Padding="15">

                    <VerticalStackLayout Spacing="12">

                        <Grid ColumnDefinitions="*,Auto">
                            <Entry x:Name="eGerName" Placeholder="Deutscher Name"/>
                            <Button Grid.Column="1" Text="💡" Clicked="BtnHelpGerName_Clicked"/>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <Entry x:Name="eLatName" Placeholder="Lateinischer Name"/>
                            <Button Grid.Column="1" Text="💡" Clicked="BtnHelpLat_Clicked"/>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <Entry x:Name="eGerFamily" Placeholder="Deutsche Familie"/>
                            <Button Grid.Column="1" Text="💡" Clicked="BtnGerFam_Clicked"/>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <Entry x:Name="eLatFamily" Placeholder="Lateinische Familie"/>
                            <Button Grid.Column="1" Text="💡" Clicked="BtnLatFam_Clicked"/>
                        </Grid>

                        <Button Text="✔ Überprüfen"
                                BackgroundColor="#2196F3"
                                TextColor="White"
                                Clicked="BtnCheck_Clicked"/>

                        <Button Text="➡ Nächste Pflanze"
                                BackgroundColor="#FF9800"
                                TextColor="White"
                                Clicked="naechstepflanze"/>

                        <Grid ColumnDefinitions="*,*">

                            <Button Text="✓ Richtig"
                                    BackgroundColor="#4CAF50"
                                    TextColor="White"
                                    Clicked="RichtigMarkieren_Clicked"/>

                            <Button Grid.Column="1"
                                    Text="✗ Falsch"
                                    BackgroundColor="#F44336"
                                    TextColor="White"
                                    Clicked="Button_Clicked"/>

                        </Grid>

                        <Label x:Name="lblCorrect" Text="✓ 0" TextColor="Green"/>
                        <Label x:Name="lblWrong" Text="✗ 0" TextColor="Red"/>
    
                    </VerticalStackLayout>

                </Border>

            </Grid>

        </Grid>

    </ScrollView>

</ContentPage>