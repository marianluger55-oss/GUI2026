<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HerbariumLearnApp.MainPage"
             Title="Herbarium Lern App">
                
             

    <ScrollView>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="100" />
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Stroke="LightGray" StrokeThickness="3" Grid.Row="0" Grid.Column="0">
                <HorizontalStackLayout>
                    <Button
                    Text="Verzeichnis auswählen:" 
                            Clicked="Verzeichnisauswählen" 
                            HeightRequest="20">
                </Button>
                    <Label
                         x:Name="eFolderContent" HeightRequest="20"/>      
                </HorizontalStackLayout>
            </Border>
            <Border Stroke="LightGray" StrokeThickness="3" Grid.Row="0" Grid.Column="1">
                <HorizontalStackLayout VerticalOptions="Center" HorizontalOptions="Center">
                    <Label Text="4/5"></Label>
                </HorizontalStackLayout>
            </Border>
            <Border Stroke="LightGray" StrokeThickness="3" Grid.Row="1" Grid.Column="0">
                <CarouselView x:Name="cvPlants">
                    <CarouselView.ItemTemplate>
                        <DataTemplate>
                            <Image Aspect="AspectFit" Source="{Binding .}">
                            </Image>
                        </DataTemplate>
                    </CarouselView.ItemTemplate>
                </CarouselView>
            </Border>
            <Border Stroke="LightGray" StrokeThickness="3" Grid.Row="1" Grid.Column="1">
                <Grid ColumnDefinitions="*,*,*,*" RowDefinitions="*,*,*,*,*,*" VerticalOptions="Center" RowSpacing="15" ColumnSpacing="15">
                    <Label Text="Dt. Name" Grid.Row="0" Grid.Column="0"></Label>
                    <Entry Grid.Column="1" Grid.Row="0" x:Name="eGerName">
                    </Entry>
                    <Button Text="H" 
                            Clicked="BtnHelpGerName_Clicked"
                            Grid.Column="2"
                            Grid.Row="0">
                    </Button>
                    <Label Text="Lt. Name" Grid.Row="1" Grid.Column="0"></Label>
                    <Entry Grid.Column="1" Grid.Row="1" x:Name="eLatName">
                    </Entry>
                    <Button Text="H" 
                        Clicked="BtnHelpLat_Clicked"
                            Grid.Column="2"
                            Grid.Row="1">
                    </Button>
                    <Label Text="Dt. Familie" Grid.Row="2" Grid.Column="0"></Label>
                    <Entry Grid.Column="1" Grid.Row="2" x:Name="eGerFamily">
                    </Entry>
                    <Button Text="H" 
                        Clicked="BtnGerFam_Clicked"
                            Grid.Column="2"
                            Grid.Row="2">
                    </Button>
                    <Label Text="DL. Familie" Grid.Row="3" Grid.Column="0"></Label>
                    <Entry Grid.Column="1" Grid.Row="3" x:Name="eLatFamily">
                    </Entry>
                    <Button Text="H" 
                        Clicked="BtnLatFam_Clicked"
                            Grid.Column="2"
                            Grid.Row="3">
                    </Button>
                    <Button Text="Überprüfen"
                            Clicked="BtnCheck_Clicked"
                            Grid.ColumnSpan="2"
                            Grid.Row="4"
                            Grid.Column="0"></Button>
                    <Button Text="Nächste Pflanze"
                       Clicked="naechstepflanze"
                            Grid.Row="4"
                            Grid.Column="2"
                            Grid.ColumnSpan="2">
                    </Button>
                    <Button Text="Richtig markieren"
                    Grid.Row="5" Grid.Column="0" Clicked="RichtigMarkieren_Clicked" Grid.ColumnSpan="2"></Button>
                    <Button Text="Falsch markieren"
                    Grid.Row="5" Grid.Column="2" Grid.ColumnSpan="2" Clicked="Button_Clicked"></Button>
                </Grid>
            </Border>
        </Grid>
    </ScrollView>

</ContentPage>
