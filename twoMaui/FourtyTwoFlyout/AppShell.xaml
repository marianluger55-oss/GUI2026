<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FourtyTwoFlyout.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:FourtyTwoFlyout"
    Title="FourtyTwoFlyout">

    <FlyoutItem Title="Home">
        <ShellContent>
            <ContentPage>
                <Label Text="Welcome to Home"></Label>
            </ContentPage>
        </ShellContent>
    </FlyoutItem>
    <FlyoutItem Title="Einstellungen">
        <ShellContent>
            <ContentPage>
                <Label Text="Welcome to Einstellungen"></Label>
            </ContentPage>
        </ShellContent>
    </FlyoutItem>
    <FlyoutItem Title="Main">
        <ShellContent ContentTemplate="{DataTemplate local:MainPage}"></ShellContent>
    </FlyoutItem>
    <FlyoutItem Title="Detail">
        <ShellContent ContentTemplate="{DataTemplate local:TitlePage}"></ShellContent>
    </FlyoutItem>

</Shell>
